        "command": "dartscript.chordMenu.llm",
        "key": "ctrl+shift+l"
      },
      {
        "command": "dartscript.chordMenu.chat",
        "key": "ctrl+shift+a"
      },
      {
        "command": "dartscript.chordMenu.tomAiChat",
        "key": "ctrl+shift+t"
      },
      {
        "command": "dartscript.chordMenu.execute",
        "key": "ctrl+shift+e"
      },
      {
        "command": "dartscript.chordMenu.executeKey",
        "key": "ctrl+shift+a",
